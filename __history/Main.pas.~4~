unit Main;

interface

uses
  Winapi.Windows, Winapi.Messages,
  System.SysUtils, System.Variants, System.Classes,
  System.JSON,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms,
  Vcl.Dialogs, Vcl.StdCtrls,
  IdHTTPServer, IdCustomHTTPServer, IdContext,
  Contnrs, UProdutoModel;

type
  TForm1 = class(TForm)
    MemoLog: TMemo;
    btnStart: TButton;
    btnStop: TButton;
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure btnStartClick(Sender: TObject);
    procedure btnStopClick(Sender: TObject);
  private
    HttpServer: TIdHTTPServer;
    Produtos: TObjectList;

    procedure CarregarProdutos;

    procedure OnGetRequest(
      AContext: TIdContext;
      ARequestInfo: TIdHTTPRequestInfo;
      AResponseInfo: TIdHTTPResponseInfo);

    procedure OnOtherRequest(
      AContext: TIdContext;
      ARequestInfo: TIdHTTPRequestInfo;
      AResponseInfo: TIdHTTPResponseInfo);

    procedure RetornarProdutos(
      Response: TIdHTTPResponseInfo);

    procedure RetornarProdutoPorId(
      Url: String;
      Response: TIdHTTPResponseInfo);

    procedure CriarProduto(
      Request: TIdHTTPRequestInfo;
      Response: TIdHTTPResponseInfo);
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);
begin
  Produtos := TObjectList.Create(True);
  HttpServer := nil;

  CarregarProdutos;
end;

procedure TForm1.FormDestroy(Sender: TObject);
begin
  if Assigned(HttpServer) then
    FreeAndNil(HttpServer);

  FreeAndNil(Produtos);
end;

procedure TForm1.btnStartClick(Sender: TObject);
begin
  if Assigned(HttpServer) then
  begin
    MemoLog.Lines.Add('Servidor já iniciado.');
    Exit;
  end;

  HttpServer := TIdHTTPServer.Create(nil);

  HttpServer.DefaultPort := 8080;
  HttpServer.OnCommandGet := OnGetRequest;
  HttpServer.OnCommandOther := OnOtherRequest;

  HttpServer.Active := True;

  MemoLog.Lines.Add('API ONLINE - Porta 8080');
end;

procedure TForm1.btnStopClick(Sender: TObject);
begin
  if Assigned(HttpServer) then
  begin
    HttpServer.Active := False;
    FreeAndNil(HttpServer);
  end;

  MemoLog.Lines.Add('API OFFLINE');
end;

procedure TForm1.CarregarProdutos;
var
  P: TProduto;
begin
  P := TProduto.Create;
  P.Id := 1;
  P.Nome := 'Notebook';
  P.Preco := 3500;
  Produtos.Add(P);

  P := TProduto.Create;
  P.Id := 2;
  P.Nome := 'Mouse';
  P.Preco := 120;
  Produtos.Add(P);
end;

procedure TForm1.OnGetRequest(
  AContext: TIdContext;
  ARequestInfo: TIdHTTPRequestInfo;
  AResponseInfo: TIdHTTPResponseInfo);
begin

  if ARequestInfo.Document = '/api/status' then
  begin
    AResponseInfo.ContentType := 'application/json';
    AResponseInfo.ContentText := '{"status":"online"}';
    Exit;
  end;

  if ARequestInfo.Document = '/api/produtos' then
  begin
    RetornarProdutos(AResponseInfo);
    Exit;
  end;

  if Pos('/api/produtos/', ARequestInfo.Document) = 1 then
  begin
    RetornarProdutoPorId(
      ARequestInfo.Document,
      AResponseInfo);
    Exit;
  end;

  AResponseInfo.ResponseNo := 404;
  AResponseInfo.ContentType := 'application/json';
  AResponseInfo.ContentText :=
    '{"erro":"rota nao encontrada"}';
end;

procedure TForm1.RetornarProdutos(
  Response: TIdHTTPResponseInfo);
var
  I: Integer;
  P: TProduto;
  Json: string;
  FS: TFormatSettings;
begin

  FS := FormatSettings;
  FS.DecimalSeparator := '.';

  Json := '[';

  for I := 0 to Produtos.Count - 1 do
  begin
    P := TProduto(Produtos[I]);

    Json := Json +
      Format(
      '{"id":%d,"nome":"%s","preco":%s}',
      [
        P.Id,
        P.Nome,
        FloatToStr(P.Preco, FS)
      ]);

    if I < Produtos.Count - 1 then
      Json := Json + ',';
  end;

  Json := Json + ']';

  Response.ContentType := 'application/json';
  Response.ContentText := Json;
end;

procedure TForm1.RetornarProdutoPorId(
  Url: String;
  Response: TIdHTTPResponseInfo);
var
  Id: Integer;
  I: Integer;
  P: TProduto;
  FS: TFormatSettings;
begin

  FS := FormatSettings;
  FS.DecimalSeparator := '.';

  Id := StrToIntDef(
    Copy(
      Url,
      Length('/api/produtos/') + 1,
      MaxInt
    ),
    0
  );

  for I := 0 to Produtos.Count - 1 do
  begin
    P := TProduto(Produtos[I]);

    if P.Id = Id then
    begin
      Response.ContentType := 'application/json';

      Response.ContentText :=
        Format(
        '{"id":%d,"nome":"%s","preco":%s}',
        [
          P.Id,
          P.Nome,
          FloatToStr(P.Preco, FS)
        ]);

      Exit;
    end;
  end;

  Response.ResponseNo := 404;
  Response.ContentType := 'application/json';
  Response.ContentText :=
    '{"erro":"produto nao encontrado"}';
end;

procedure TForm1.OnOtherRequest(
  AContext: TIdContext;
  ARequestInfo: TIdHTTPRequestInfo;
  AResponseInfo: TIdHTTPResponseInfo);
begin

  if (ARequestInfo.Command = 'POST') and
     (ARequestInfo.Document = '/api/produtos') then
  begin
    CriarProduto(
      ARequestInfo,
      AResponseInfo);

    Exit;
  end;

  AResponseInfo.ResponseNo := 404;
  AResponseInfo.ContentType := 'application/json';
  AResponseInfo.ContentText :=
    '{"erro":"rota nao encontrada"}';
end;

procedure TForm1.CriarProduto(
  Request: TIdHTTPRequestInfo;
  Response: TIdHTTPResponseInfo);
var
  Stream: TStringStream;
  Body: string;
  Json: TJSONObject;
  Produto: TProduto;
begin

  if not Assigned(Request.PostStream) then
  begin
    Response.ResponseNo := 400;
    Response.ContentText :=
      '{"erro":"body nao informado"}';
    Exit;
  end;

  Stream := TStringStream.Create('');
  try

    Request.PostStream.Position := 0;

    Stream.CopyFrom(
      Request.PostStream,
      Request.PostStream.Size);

    Body := Stream.DataString;

    MemoLog.Lines.Add('JSON Recebido:');
    MemoLog.Lines.Add(Body);

    Json := TJSONObject.ParseJSONValue(Body)
      as TJSONObject;

    try

      Produto := TProduto.Create;

      Produto.Id :=
        Json.GetValue<Integer>('id');

      Produto.Nome :=
        Json.GetValue<string>('nome');

      Produto.Preco :=
        Json.GetValue<Double>('preco');

      Produtos.Add(Produto);

      Response.ContentType :=
        'application/json';

      Response.ContentText :=
        '{"mensagem":"produto criado"}';

    finally
      Json.Free;
    end;

  finally
    Stream.Free;
  end;
end;

end.
